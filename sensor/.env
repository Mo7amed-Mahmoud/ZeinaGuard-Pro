# ── ZeinaGuard Sensor — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values before starting the sensor.

# Backend URL — point to your Replit backend or local Flask server
# Local development:
BACKEND_URL=http://localhost:8000
# Production (Replit):
# BACKEND_URL=https://your-replit-dev-domain

# Sensor credentials (must match backend auth users)
SENSOR_USER=admin
SENSOR_PASSWORD=admin123

# Wi-Fi interface to use (leave blank to auto-detect)
# SENSOR_INTERFACE=wlan0mon

# Unique sensor identifier (defaults to hostname)
# ZEINAGUARD_SENSOR_ID=sensor-raspberry-01

# Active containment — sends deauth frames to kick clients from rogue APs
# WARNING: Illegal in some jurisdictions. Disable if unsure.
ENABLE_CONTAINMENT=False

# Deauth parameters (used only if ENABLE_CONTAINMENT=True)
DEAUTH_COUNT=40
DEAUTH_INTERVAL=0.1

# Scan batching
SCAN_EMIT_BATCH_SIZE=25
SCAN_EMIT_INTERVAL_SECONDS=3.0
